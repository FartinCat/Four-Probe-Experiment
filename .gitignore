# ── Virtual Environment ────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Python cache & compiled files ─────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ── Flask session files ────────────────────────────────────
.flask_session/
flask_session/

# ── Environment variables / secrets ───────────────────────
.env
.env.*
*.env

# ── Exported data files ────────────────────────────────────
*.csv
*.xlsx
*.json.bak

# ── OS generated files ─────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editor / IDE folders ───────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Build / dist artifacts ────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Pytest / coverage ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── These files SHOULD be committed (do not ignore) ───────
# app.py
# requirements.txt
# Procfile
# runtime.txt
# setup.sh
# setup.bat
# README.md
# .gitignore
# templates/
# static/
